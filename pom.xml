<project xmlns="http://maven.apache.org/POM/4.0.0"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
	<modelVersion>4.0.0</modelVersion>

	<groupId>org.eclipse.osgi-technology.featurelauncher.container</groupId>
	<artifactId>container</artifactId>
	<version>1.0.0-SNAPSHOT</version>
	<packaging>pom</packaging>

	<name>OSGi Feature Launcher Container Images</name>
	<description>Builds 16 container images (4 base images x 4 launcher variants) using a shared Dockerfile with args-files.</description>
	<url>https://github.com/eclipse-osgi-technology/container.feature-launcher</url>

	<properties>
		<project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
		<featurelauncher.version>1.0.0-SNAPSHOT</featurelauncher.version>

		<!-- Defaults (override via -D or profiles) -->
		<base.image>eclipse-temurin:17-jre-noble</base.image>
		<base.tag>eclipse-temurin-17</base.tag>
		<variant>local-base</variant>
		<launcher.artifact>all.lite</launcher.artifact>
		<run.user>1000</run.user>
	</properties>

	<repositories>
		<repository>
			<id>central-snapshots</id>
			<name>Central Snapshots</name>
			<url>https://central.sonatype.com/repository/maven-snapshots/</url>
			<releases><enabled>false</enabled></releases>
			<snapshots><enabled>true</enabled></snapshots>
		</repository>
	</repositories>

	<profiles>
		<!-- === Base image profiles === -->
		<profile>
			<id>eclipse-temurin-17</id>
			<properties>
				<base.image>eclipse-temurin:17-jre-noble</base.image>
				<base.tag>eclipse-temurin-17</base.tag>
				<run.user>1000</run.user>
			</properties>
		</profile>
		<profile>
			<id>eclipse-temurin-25</id>
			<properties>
				<base.image>eclipse-temurin:25-jre-noble</base.image>
				<base.tag>eclipse-temurin-25</base.tag>
				<run.user>1000</run.user>
			</properties>
		</profile>
		<profile>
			<id>chiseled</id>
			<properties>
				<base.image>ubuntu/jre:21-24.04_stable</base.image>
				<base.tag>ubuntu-chiseled-21</base.tag>
				<run.user>nonroot</run.user>
			</properties>
		</profile>
		<profile>
			<id>distroless</id>
			<properties>
				<base.image>gcr.io/distroless/java25-debian13:nonroot</base.image>
				<base.tag>grc-distroless-25</base.tag>
				<run.user>nonroot</run.user>
			</properties>
		</profile>

		<!-- === Variant profiles === -->
		<profile>
			<id>local-base</id>
			<properties>
				<variant>local-base</variant>
				<launcher.artifact>all.lite</launcher.artifact>
			</properties>
		</profile>
		<profile>
			<id>remote-base</id>
			<properties>
				<variant>remote-base</variant>
				<launcher.artifact>all.maven</launcher.artifact>
			</properties>
		</profile>
		<profile>
			<id>local-directory-installer</id>
			<properties>
				<variant>local-directory-installer</variant>
				<launcher.artifact>all.lite</launcher.artifact>
			</properties>
		</profile>
		<profile>
			<id>remote-http-installer</id>
			<properties>
				<variant>remote-http-installer</variant>
				<launcher.artifact>all.maven</launcher.artifact>
			</properties>
		</profile>
	</profiles>
</project>
