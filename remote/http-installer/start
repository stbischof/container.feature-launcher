#!/bin/sh
set -e

# =============================================================================
# OSGi Feature Launcher - Startup Script (HTTP Installer)
#
# Launches the OSGi framework with a bootstrap feature.
# The bootstrap feature is configured via OSGITECH_BOOTSTRAP_FEATURE.
# =============================================================================

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Source environment configuration
if [ -f "$SCRIPT_DIR/env.conf" ]; then
    . "$SCRIPT_DIR/env.conf"
fi

# Allow override via /etc/osgitech/env.conf
if [ -f "/etc/osgitech/env.conf" ]; then
    . "/etc/osgitech/env.conf"
fi

# Check if java works
if ! java -version >/dev/null 2>&1; then
    echo "Java is installed but not working properly (java -version failed)."
    exit 1
fi

# -----------------------------------------------------------------------------
# Build JVM arguments
# -----------------------------------------------------------------------------
JVM_ARGS="$JAVA_OPTS"
if [ -n "$JAVA_HEAP_MAX" ]; then
    JVM_ARGS="-Xmx${JAVA_HEAP_MAX} $JVM_ARGS"
fi

# -----------------------------------------------------------------------------
# Validate bootstrap feature
# -----------------------------------------------------------------------------
if [ ! -f "$OSGITECH_BOOTSTRAP_FEATURE" ]; then
    echo "ERROR: Bootstrap feature not found!"
    echo "Expected: $OSGITECH_BOOTSTRAP_FEATURE"
    echo "Set OSGITECH_BOOTSTRAP_FEATURE to override."
    exit 1
fi

# -----------------------------------------------------------------------------
# Display info
# -----------------------------------------------------------------------------
echo "=== OSGi Feature Launcher (HTTP Installer) ==="
echo "Bootstrap:     $OSGITECH_BOOTSTRAP_FEATURE"
echo "Features URL:  $OSGITECH_HTTP_FEATURES_URL"
echo "Scan Mode:     $OSGITECH_HTTP_SCAN_MODE"
echo "Scan Interval: $OSGITECH_HTTP_SCAN_INTERVAL"
if [ -n "$OSGITECH_HTTP_SERVER_ID" ]; then
echo "Server ID:     $OSGITECH_HTTP_SERVER_ID"
fi
echo "JDK:           $(java -version 2>&1 | head -1)"
echo "================================================"

# -----------------------------------------------------------------------------
# Build launcher arguments
# -----------------------------------------------------------------------------
LAUNCHER_ARGS=""

# Bootstrap feature
LAUNCHER_ARGS="$LAUNCHER_ARGS -f $OSGITECH_BOOTSTRAP_FEATURE"

# Local repository
LAUNCHER_ARGS="$LAUNCHER_ARGS -a file://$OSGITECH_REPO_DIR"

# Default repos
if [ "$OSGITECH_USE_DEFAULT_REPOS" = "true" ]; then
    LAUNCHER_ARGS="$LAUNCHER_ARGS --impl-default-repos"
fi

# Extra repos
if [ -n "$OSGITECH_EXTRA_REPOS" ]; then
    OLD_IFS="$IFS"
    IFS=','
    for repo in $OSGITECH_EXTRA_REPOS; do
        LAUNCHER_ARGS="$LAUNCHER_ARGS -a $repo"
    done
    IFS="$OLD_IFS"
fi

# Framework properties
LAUNCHER_ARGS="$LAUNCHER_ARGS -l org.osgi.framework.storage=/app/storage/framework"
LAUNCHER_ARGS="$LAUNCHER_ARGS -l org.osgi.framework.storage.clean=onFirstInit"

# HTTP Installer properties
if [ -n "$OSGITECH_HTTP_FEATURES_URL" ]; then
    LAUNCHER_ARGS="$LAUNCHER_ARGS -l osgi.technology.featurelauncher.extras.installer.http.simple.features.url=$OSGITECH_HTTP_FEATURES_URL"
fi
LAUNCHER_ARGS="$LAUNCHER_ARGS -l osgi.technology.featurelauncher.extras.installer.http.simple.repo.dir=$OSGITECH_REPO_DIR"
LAUNCHER_ARGS="$LAUNCHER_ARGS -l osgi.technology.featurelauncher.extras.installer.http.simple.scan.mode=$OSGITECH_HTTP_SCAN_MODE"
LAUNCHER_ARGS="$LAUNCHER_ARGS -l osgi.technology.featurelauncher.extras.installer.http.simple.scan.interval=$OSGITECH_HTTP_SCAN_INTERVAL"
LAUNCHER_ARGS="$LAUNCHER_ARGS -l osgi.technology.featurelauncher.extras.installer.http.simple.connect.timeout=$OSGITECH_HTTP_CONNECT_TIMEOUT"
LAUNCHER_ARGS="$LAUNCHER_ARGS -l osgi.technology.featurelauncher.extras.installer.http.simple.request.timeout=$OSGITECH_HTTP_REQUEST_TIMEOUT"
if [ -n "$OSGITECH_HTTP_SERVER_ID" ]; then
    LAUNCHER_ARGS="$LAUNCHER_ARGS -l osgi.technology.featurelauncher.extras.installer.http.simple.server.id=$OSGITECH_HTTP_SERVER_ID"
fi

# Extension handlers
if [ -n "$OSGITECH_EXTENSION_HANDLERS" ]; then
    OLD_IFS="$IFS"
    IFS=','
    for handler in $OSGITECH_EXTENSION_HANDLERS; do
        LAUNCHER_ARGS="$LAUNCHER_ARGS -e $handler"
    done
    IFS="$OLD_IFS"
fi

# Additional arguments passed to script
LAUNCHER_ARGS="$LAUNCHER_ARGS $@"

# -----------------------------------------------------------------------------
# Launch
# -----------------------------------------------------------------------------
echo "Launching OSGi Framework..."
echo "================================================"
exec java $JVM_ARGS -jar /app/launcher.jar $LAUNCHER_ARGS
