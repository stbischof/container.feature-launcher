#!/bin/sh
set -e

# =============================================================================
# OSGi Feature Launcher - Startup Script (Directory Installer)
#
# Launches the OSGi framework with a bootstrap feature.
# The bootstrap feature is configured via OSGITECH_BOOTSTRAP_FEATURE.
#
# The installer.directory bundle scans $OSGITECH_DIR_INSTALLER_FEATURES_DIR
# for additional features at runtime.
# =============================================================================

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Source environment configuration
if [ -f "$SCRIPT_DIR/env.conf" ]; then
    . "$SCRIPT_DIR/env.conf"
fi

# Allow override via /etc/osgitech/env.conf
if [ -f "/etc/osgitech/env.conf" ]; then
    . "/etc/osgitech/env.conf"
fi

# Check if java works
if ! java -version >/dev/null 2>&1; then
    echo "Java is installed but not working properly (java -version failed)."
    exit 1
fi

# -----------------------------------------------------------------------------
# Build JVM arguments
# -----------------------------------------------------------------------------
JVM_ARGS="$JAVA_OPTS"
if [ -n "$JAVA_HEAP_MAX" ]; then
    JVM_ARGS="-Xmx${JAVA_HEAP_MAX} $JVM_ARGS"
fi

# -----------------------------------------------------------------------------
# Validate bootstrap feature
# -----------------------------------------------------------------------------
if [ ! -f "$OSGITECH_BOOTSTRAP_FEATURE" ]; then
    echo "ERROR: Bootstrap feature not found!"
    echo "Expected: $OSGITECH_BOOTSTRAP_FEATURE"
    echo "Set OSGITECH_BOOTSTRAP_FEATURE to override."
    exit 1
fi

# -----------------------------------------------------------------------------
# Initial content loading (first start only)
# -----------------------------------------------------------------------------
CONTENT_MARKER="$OSGITECH_DIR_INSTALLER_FEATURES_DIR/.content-loaded"
MERGED_COUNT=0
if [ -f "$CONTENT_MARKER" ]; then
    echo "Initial content already loaded (marker: $CONTENT_MARKER). Skipping."
elif [ -d "$OSGITECH_INITIAL_CONTENT_DIR" ]; then
    for content_dir in "$OSGITECH_INITIAL_CONTENT_DIR"/*/; do
        [ -d "$content_dir" ] || continue
        content_name="$(basename "$content_dir")"

        # Copy feature JSON files (add UUID to avoid name clashes)
        if [ -d "$content_dir/features" ]; then
            for feature_file in "$content_dir/features"/*.json; do
                [ -f "$feature_file" ] || continue
                uuid="$(cat /proc/sys/kernel/random/uuid)"
                base="$(basename "$feature_file" .json)"
                cp "$feature_file" "$OSGITECH_DIR_INSTALLER_FEATURES_DIR/${base}-${uuid}.json"
                echo "  Merged feature: $content_name/$(basename "$feature_file") -> ${base}-${uuid}.json"
            done
        fi

        # Merge repo (try hard link first, fall back to copy; no-clobber)
        if [ -d "$content_dir/repo" ]; then
            if cp -rln "$content_dir/repo/." "$OSGITECH_DIR_INSTALLER_REPO_DIR/" 2>/dev/null; then
                echo "  Merged repo:    $content_name/repo -> $OSGITECH_DIR_INSTALLER_REPO_DIR (hard linked)"
            else
                cp -rn "$content_dir/repo/." "$OSGITECH_DIR_INSTALLER_REPO_DIR/"
                echo "  Merged repo:    $content_name/repo -> $OSGITECH_DIR_INSTALLER_REPO_DIR (copied)"
            fi
        fi

        MERGED_COUNT=$((MERGED_COUNT + 1))
    done
    if [ -d "$OSGITECH_DIR_INSTALLER_FEATURES_DIR" ]; then
        touch "$CONTENT_MARKER"
    fi
    echo "Loaded initial content from $MERGED_COUNT source(s)"
fi

# -----------------------------------------------------------------------------
# Display info
# -----------------------------------------------------------------------------
echo "=== OSGi Feature Launcher (Directory Installer) ==="
echo "Bootstrap:    $OSGITECH_BOOTSTRAP_FEATURE"
echo "Features Dir: $OSGITECH_DIR_INSTALLER_FEATURES_DIR"
echo "Repo Dir:     $OSGITECH_DIR_INSTALLER_REPO_DIR"
if [ -f "$CONTENT_MARKER" ] && [ "$MERGED_COUNT" -eq 0 ]; then
echo "Content:      already loaded (skipped)"
else
echo "Content:      $MERGED_COUNT source(s) from $OSGITECH_INITIAL_CONTENT_DIR"
fi
echo "Scan Mode:    $OSGITECH_DIR_INSTALLER_SCAN_MODE"
echo "Scan Interval: $OSGITECH_DIR_INSTALLER_SCAN_INTERVAL"
echo "JDK:          $(java -version 2>&1 | head -1)"
echo "===================================================="

# -----------------------------------------------------------------------------
# Build launcher arguments
# -----------------------------------------------------------------------------
LAUNCHER_ARGS=""

# Bootstrap feature
LAUNCHER_ARGS="$LAUNCHER_ARGS -f $OSGITECH_BOOTSTRAP_FEATURE"

# Local repository
LAUNCHER_ARGS="$LAUNCHER_ARGS -a file://$OSGITECH_REPO_DIR"

# Framework properties
LAUNCHER_ARGS="$LAUNCHER_ARGS -l org.osgi.framework.storage=/app/storage/framework"
LAUNCHER_ARGS="$LAUNCHER_ARGS -l org.osgi.framework.storage.clean=onFirstInit"

# Directory Installer properties
LAUNCHER_ARGS="$LAUNCHER_ARGS -l osgi.technology.featurelauncher.extras.installer.directory.features.dir=$OSGITECH_DIR_INSTALLER_FEATURES_DIR"
LAUNCHER_ARGS="$LAUNCHER_ARGS -l osgi.technology.featurelauncher.extras.installer.directory.repo.dir=$OSGITECH_DIR_INSTALLER_REPO_DIR"
LAUNCHER_ARGS="$LAUNCHER_ARGS -l osgi.technology.featurelauncher.extras.installer.directory.scan.mode=$OSGITECH_DIR_INSTALLER_SCAN_MODE"
LAUNCHER_ARGS="$LAUNCHER_ARGS -l osgi.technology.featurelauncher.extras.installer.directory.scan.interval=$OSGITECH_DIR_INSTALLER_SCAN_INTERVAL"

# Extension handlers
if [ -n "$OSGITECH_EXTENSION_HANDLERS" ]; then
    OLD_IFS="$IFS"
    IFS=','
    for handler in $OSGITECH_EXTENSION_HANDLERS; do
        LAUNCHER_ARGS="$LAUNCHER_ARGS -e $handler"
    done
    IFS="$OLD_IFS"
fi

# Additional arguments passed to script
LAUNCHER_ARGS="$LAUNCHER_ARGS $@"

# -----------------------------------------------------------------------------
# Launch
# -----------------------------------------------------------------------------
echo "Launching OSGi Framework..."
echo "===================================================="
exec java $JVM_ARGS -jar /app/launcher.jar $LAUNCHER_ARGS
